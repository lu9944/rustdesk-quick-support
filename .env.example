# RustDesk QuickSupport Configuration
# Copy this file to .env and fill in your actual values.

# Rendezvous server address (default: rs-ny.rustdesk.com)
RUSTDESK_SERVER=

# Optional: Server authentication key
RUSTDESK_KEY=

# Optional: Socks5 proxy (format: proxy_host:proxy_port)
RUSTDESK_SOCKS5=

# Optional: Pre-set device ID (auto-generated if empty)
RUSTDESK_ID=

# Optional: Pre-set password (auto-generated if empty)
RUSTDESK_PASSWORD=
